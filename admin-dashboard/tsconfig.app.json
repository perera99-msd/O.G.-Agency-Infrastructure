{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "components/*": ["./src/dashdark/components/*"],
      "layouts/*": ["./src/dashdark/layouts/*"],
      "pages/*": ["./src/dashdark/pages/*"],
      "routes/*": ["./src/dashdark/routes/*"],
      "theme/*": ["./src/dashdark/theme/*"],
      "utils/*": ["./src/dashdark/utils/*"],
      "data/*": ["./src/dashdark/data/*"],
      "assets/*": ["./src/dashdark/assets/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
